{
  "name": "realtime-push-simulator",
  "version": "1.0.0",
  "private": true,
  "description": "浏览器端高频实时数据推送渲染方案演示 - gRPC Streaming + WebWorker + Map 缓存 + rAF 节流",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "server": "node server/server.mjs",
    "start": "concurrently \"npm run server\" \"npm run dev\""
  },
  "dependencies": {
    "@types/leaflet": "^1.9.21",
    "leaflet": "^1.9.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-leaflet": "^4.2.1"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.2",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  }
}
